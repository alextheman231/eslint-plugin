{
  "name": "@alextheman/eslint-plugin",
  "version": "5.10.2",
  "description": "A package to provide custom ESLint rules and configs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/eslint-plugin.git"
  },
  "license": "MIT",
  "author": "alextheman",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js",
      "require": "./dist/internal/index.cjs",
      "default": "./dist/internal/index.js"
    },
    "./utility": {
      "types": "./dist/utility/index.d.ts",
      "import": "./dist/utility/index.js",
      "require": "./dist/utility/index.cjs",
      "default": "./dist/utility/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "create-feature-docs": "typedoc",
    "create-local-package": "pnpm run build && rm -f alextheman-eslint-plugin-*.tgz && pnpm pack",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-prettier && pnpm run format-eslint",
    "format-and-build": "tsx src/utility/checkConfigChanges.ts || pnpm run build && pnpm run format",
    "format-eslint": "eslint --fix --suppress-all \"src/**/*.ts\" \"tests/**/*.ts\" \"package.json\" && rm -f eslint-suppressions.json",
    "format-prettier": "pnpm run format-prettier-typescript && pnpm run format-prettier-javascript && pnpm run format-prettier-yml",
    "format-prettier-javascript": "prettier --write \"./**/*.js\"",
    "format-prettier-typescript": "prettier --write --parser typescript \"./**/*.ts\"",
    "format-prettier-yml": "prettier --write \"./**/*.yml\"",
    "lint": "pnpm run lint-tsc && pnpm run lint-eslint && pnpm run lint-prettier && pnpm run lint-pre-release",
    "lint-and-build": "tsx src/utility/checkConfigChanges.ts || pnpm run build && pnpm run lint",
    "lint-eslint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"package.json\"",
    "lint-pre-release": "alex-c-line package-json check --rules no-pre-release-dependencies",
    "lint-prettier": "pnpm run lint-prettier-typescript && pnpm run lint-prettier-javascript && pnpm run lint-prettier-yml",
    "lint-prettier-javascript": "prettier --check \"./**/*.js\"",
    "lint-prettier-typescript": "prettier --check --parser typescript \"./**/*.ts\"",
    "lint-prettier-yml": "prettier --check \"./**/*.{yml,yaml}\"",
    "lint-tsc": "tsc --noEmit",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "test": "vitest run",
    "test-end-to-end": "RUN_END_TO_END=true vitest run tests/end-to-end --reporter verbose",
    "test-watch": "vitest",
    "update-dependencies": "pnpm update --latest && pnpm update",
    "use-local-package": "bash -c 'alex-c-line use-local-package $@' --"
  },
  "dependencies": {
    "@alextheman/utility": "^5.7.0",
    "@eslint/compat": "^2.0.3",
    "@typescript-eslint/types": "^8.57.2",
    "@typescript-eslint/utils": "^8.57.2",
    "common-tags": "^1.8.2",
    "prettier": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/common-tags": "^1.8.4",
    "@types/eslint": "^9.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/rule-tester": "^8.57.2",
    "alex-c-line": "^2.3.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-package-json": "^0.91.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-vitest-rule-tester": "^3.1.0",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "tempy": "^3.2.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-rhineai-theme": "^1.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@eslint/js": ">=9.0.0",
    "eslint": ">=9.0.0",
    "eslint-config-prettier": ">=10.0.0",
    "eslint-import-resolver-typescript": ">=4.0.0",
    "eslint-plugin-import": ">=2.0.0",
    "eslint-plugin-jsdoc": ">=61.5.0",
    "eslint-plugin-jsx-a11y": ">=6.0.0",
    "eslint-plugin-n": ">=17.23.1",
    "eslint-plugin-package-json": ">=0.85.0",
    "eslint-plugin-perfectionist": ">=5.0.0",
    "eslint-plugin-prettier": ">=5.0.0",
    "eslint-plugin-react": ">=7.0.0",
    "eslint-plugin-react-hooks": ">=7.0.0",
    "eslint-plugin-react-refresh": ">=0.4.0",
    "typedoc": ">=0.28.15",
    "typedoc-plugin-markdown": ">=4.9.0",
    "typedoc-rhineai-theme": ">=1.2.0",
    "typescript-eslint": ">=8.0.0",
    "vite-tsconfig-paths": ">=5.1.4",
    "vitest": ">=4.0.13"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "tsdown": "<0.21.0",
      "typescript": "<6.0.0"
    },
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
